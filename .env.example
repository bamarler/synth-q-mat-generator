# Copy to .env and fill in. .env is gitignored and auto-loaded by the Python
# entrypoints (via synth_q_mat.config) and the HPC sbatch scripts.

# === NEEDED NOW ===========================================================
# Materials Project API key — required for `make download-data`.
# Get a free key at https://next-gen.materialsproject.org/api
MP_API_KEY=

# === OPTIONAL =============================================================
# MLflow tracking. Local default works out of the box; on HPC nodes point this
# at the workstation running `make mlflow-ui`.
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# === AWS (DVC remote: s3://synth-q-mat-artifacts/dvc) ======================
# Single-purpose IAM key, scoped to that one bucket. boto3 reads these for BOTH
# dvc[s3] (dvc push/pull) and the aws CLI, so setting them here covers both —
# no per-machine .dvc/config.local needed. (That legacy path still works.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
